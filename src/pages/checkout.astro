---
import PageLayout from "../PageLayout/PageLayout.astro";
---

<PageLayout heading="Checkout">
  <div class="checkout-wrapper">
    <h1>Checkout</h1>
    <section class="order-summary">
      <h2>Din ordre</h2>
      <div id="summary-items" class="summary-items"></div>
      <div class="summary-total">
        <span>Total</span>
        <span id="summary-total-price">0 kr.</span>
      </div>
    </section>

    <section class="checkout-form-section">
      <h2>Dine oplysninger</h2>

      <div class="form">
        <div class="field-group">
          <label for="name">Fulde navn</label>
          <input type="text" id="name" name="name" placeholder="Anders Andersen" />
        </div>

        <div class="field-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="anders@email.dk" />
        </div>

        <div class="field-group">
          <label for="phone">Telefon</label>
          <input type="tel" id="phone" name="phone" placeholder="+45 12 34 56 78" />
        </div>

        <div class="field-row">
          <div class="field-group">
            <label for="address">Adresse</label>
            <input type="text" id="address" name="address" placeholder="Strøget 1" />
          </div>
          <div class="field-group field-small">
            <label for="zip">Postnr.</label>
            <input type="text" id="zip" name="zip" placeholder="1000" />
          </div>
        </div>

        <div class="field-group">
          <label for="city">By</label>
          <input type="text" id="city" name="city" placeholder="København" />
        </div>

        <div class="field-group">
          <label for="note">Besked (valgfrit)</label>
          <textarea id="note" name="note" rows="3" placeholder="Eventuelle noter til din ordre..."></textarea>
        </div>

        <button class="btn-submit">Bekræft ordre</button>
      </div>
    </section>
  </div>
</PageLayout>

<style>
  .checkout-wrapper {
    display: grid;
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }
  .checkout-wrapper h1 {
    grid-column: 1 / -1;
  }

  @media (min-width: 768px) {
    .checkout-wrapper {
      grid-template-columns: 1fr 1.3fr;
      align-items: start;
    }
  }

  h2 {
    font-family: "Georgia", serif;
    color: #000;
    margin: 0 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #e8ddd5;
  }

  .order-summary {
    background: #fff;
    border-radius: 14px;
    padding: 1.5rem;
    top: 1rem;
  }

  .summary-total {
    display: flex;
    justify-content: space-between;
    font-size: 1rem;
    font-weight: 700;
    padding-top: 0.75rem;
    border-top: 1px solid #e8ddd5;
  }

  .empty-note {
    font-size: 0.875rem;
    color: #a08070;
  }

  .checkout-form-section {
    background: #fff;

    border-radius: 14px;
    padding: 1.5rem;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .field-row {
    display: flex;
    gap: 0.75rem;
  }

  .field-small {
    max-width: 100px;
  }

  label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  input,
  textarea {
    border: 1.5px solid #ddd5cc;
    border-radius: 8px;
    padding: 0.65rem 0.875rem;
    font-size: 0.95rem;
    color: #3d2518;
    background: #faf6f1;
    outline: none;
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
    width: 100%;
    box-sizing: border-box;
    font-family: inherit;
  }

  input:focus,
  textarea:focus {
    border-color: #7a4a3a;
    box-shadow: 0 0 0 3px rgba(122, 74, 58, 0.12);
  }

  input::placeholder,
  textarea::placeholder {
    color: #c9b8ae;
  }

  textarea {
    resize: vertical;
  }

  .btn-submit {
    background: #7a4a3a;
    color: #fff;
    border: none;
    border-radius: 9999px;
    padding: 0.9rem 2rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition:
      background 0.2s,
      transform 0.15s,
      box-shadow 0.2s;
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    background: #5c3228;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(122, 74, 58, 0.3);
  }
</style>
