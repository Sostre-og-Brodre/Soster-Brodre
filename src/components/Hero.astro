<section class="hero">
  <div class="herotext">
    <h1 class="hero-title">Søstre & Brødre</h1>
    <h2>Det handler om køn og ligestilling</h2>
  </div>

  <div class="heroimage">
    <img src="/imgs/hero.webp" alt="hero" />
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 2rem;
    gap: 2rem;
    min-height: 40vh;
  }

  .herotext {
    flex: 1;
    max-width: 40%;
  }

  .herotext h1 {
    margin-bottom: 2rem;
  }

  .herotext h2 {
    font-size: 1.1rem;
    font-weight: 400;
  }

  .heroimage {
    flex: 0 0 auto;
    width: 70%;
    max-width: 420px;
    margin-top: 3rem;
  }

  .heroimage img {
    width: 100%;
    height: auto;
    /* display: block; */
  }

  /*************** Desktop ******************/

  @media (min-width: 768px) {
    .hero {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: center;
      padding: 4rem 6rem;
      gap: 6rem;
      min-height: 40vh;
    }

    .herotext {
      flex: 0 0 auto;
      max-width: 40%;
    }

    .herotext h1 {
      margin-bottom: 2rem;
      font-size: 5rem;
      font-weight: 100;
    }

    .herotext h2 {
      font-size: 2rem;
      font-weight: 400;
    }

    .heroimage {
      flex: 0 0 auto;
      width: 70%;
      max-width: 460px;
      margin-top: 2rem;
    }

    .heroimage img {
      width: 100%;
      height: auto;
      /* display: block; */
    }
  }
</style>
