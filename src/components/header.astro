---
const currentPath = Astro.url.pathname;
---

<header class="header">
    <div class="header__wrapper">
        <a href="/" class="header__logo" aria-label="Søstre og brødre - gå til forsiden">
            <img src="/imgs/lille-logo.svg" alt="Søstre og brødre logo" width="64" height="52" />
        </a>

        <div class="header__inner">
            <button class="header__hamburger" id="hamburger-btn" aria-label="Åbn menu" aria-expanded="false" aria-controls="main-nav">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>

    <nav class="header__nav" id="main-nav">
        <a href="/shop" class={`header__nav-link ${currentPath === "/shop" ? "active" : ""}`}>Shop</a>

        <a href="/om_os" class={`header__nav-link ${currentPath === "/om-os" ? "active" : ""}`}>Om os</a>

        <a href="/artikler" class={`header__nav-link ${currentPath === "/artikler" ? "active" : ""}`}> Artikler </a>

        <a href="?" class={`header__nav-link ${currentPath === "/kurv" ? "active" : ""}`}> Kurv </a>
    </nav>
</header>

<style>
    .header {
        position: sticky;
        background-color: #a3bfb2;
    }

    .header__wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
    }

    .header__logo img {
        display: block;
        height: 60px;
        width: auto;
        padding-right: 10px;
        padding-left: 0;
    }

    .header__hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        width: 32px;
        height: 32px;
    }

    .header__hamburger span {
        display: block;
        width: 24px;
        height: 2.5px;
        background-color: #000;
        border-radius: 2px;
        transition:
            transform 0.25s ease,
            opacity 0.25s ease;
    }

    .header__hamburger[aria-expanded="true"] span:nth-child(1) {
        transform: translateY(7.5px) rotate(45deg);
    }
    .header__hamburger[aria-expanded="true"] span:nth-child(2) {
        opacity: 0;
    }
    .header__hamburger[aria-expanded="true"] span:nth-child(3) {
        transform: translateY(-7.5px) rotate(-45deg);
    }

    .header__nav {
        display: none;
        flex-direction: column;
        background: #a3bfb2;
        backdrop-filter: blur(12px);
        padding: 0.75rem 0;
        margin-top: 0.5rem;
    }

    .header__nav.is-open {
        display: flex;
    }

    .header__nav-link {
        font-size: 1.25rem;
        font-weight: 700;
        color: #000;
        text-decoration: none;
        font-family: Urbanist, sans-serif;
        padding: 0.75rem 1.5rem;
        transition: background 0.15s ease;
    }

    .header__nav-link:hover {
        background-color: #a3bfb2;
        opacity: 0.3;
    }

    .header__nav-link {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .header__nav-link.active::before {
        content: "";
        width: 14px;
        height: 14px;
        background-size: contain;
        background-repeat: no-repeat;
        display: inline-block;
    }

    @media (min-width: 768px) {
        .header {
            padding: 0.5rem 1rem;
        }

        .header__inner {
            padding: 1.5rem 2rem;
        }

        .header__hamburger {
            display: none;
        }

        .header__nav {
            display: flex;
            flex-direction: row;
            align-items: center;
            gap: 2.5rem;
            background: none;
            backdrop-filter: none;
            -webkit-backdrop-filter: none;
            border-radius: 0;
            padding: 0;
            margin-top: 0;
            position: absolute;
            top: 50%;
            right: 4rem;
            transform: translateY(-50%);
        }

        .header__nav-link {
            font-size: 0.9375rem;
            padding: 0;
            white-space: nowrap;
        }

        .header__nav-link:hover {
            background: none;
            opacity: 0.7;
        }

        .header__logo img {
            display: block;
            height: 80px;
            width: auto;
            padding-right: 10px;
            padding-left: 0;
        }

        .header__nav-link {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .header__nav-link.active::before {
            content: "";
            width: 14px;
            height: 14px;
            background-size: contain;
            background-repeat: no-repeat;
            display: inline-block;
        }
    }
</style>

<script>
    const btn = document.getElementById("hamburger-btn");
    const nav = document.getElementById("main-nav");

    btn?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("is-open");
        btn.setAttribute("aria-expanded", String(isOpen));
        btn.setAttribute("aria-label", isOpen ? "Luk menu" : "Åbn menu");
    });

    document.addEventListener("click", (e) => {
        if (!btn?.contains(e.target as Node) && !nav?.contains(e.target as Node)) {
            nav?.classList.remove("is-open");
            btn?.setAttribute("aria-expanded", "false");
            btn?.setAttribute("aria-label", "Åbn menu");
        }
    });
</script>
