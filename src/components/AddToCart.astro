---
// src/components/AddToCart.astro
// Props: id, name, price, image (valgfrit), variant (valgfrit), label (valgfrit)

export interface Props {
  id: string | number;
  name: string;
  price: number;
  image?: string;
  variant?: string;
  label?: string;
}

const {
  id,
  name,
  price,
  image = '',
  variant = '',
  label = 'Læg i kurv',
} = Astro.props;
---

<button
  class="add-to-cart-btn"
  data-product={JSON.stringify({ id, name, price, image, variant })}
  aria-label={`Tilføj ${name} til kurv`}
>
  <svg class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
    stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
    <line x1="3" y1="6" x2="21" y2="6"/>
    <path d="M16 10a4 4 0 0 1-8 0"/>
  </svg>
  <span class="btn-label">{label}</span>
  <span class="btn-added">Tilføjet ✓</span>
</button>

<style>
  .add-to-cart-btn {
    position: relative; overflow: hidden;
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #7a4a3a; color: #fff;
    border: none; border-radius: 9999px;
    padding: 0.65rem 1.4rem;
    font-size: 0.9rem; font-weight: 600; cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .add-to-cart-btn:hover {
    background: #5c3228;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(122, 74, 58, 0.35);
  }
  .btn-added {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: #4a7a5a; border-radius: inherit;
    font-size: 0.9rem; font-weight: 600;
    opacity: 0; transform: translateY(100%);
    transition: opacity 0.25s, transform 0.25s;
  }
  .add-to-cart-btn.added .btn-added { opacity: 1; transform: translateY(0); }
  .add-to-cart-btn.added .btn-label,
  .add-to-cart-btn.added .btn-icon  { opacity: 0; }
  .btn-label, .btn-icon { transition: opacity 0.2s; }
</style>

<script>
  document.querySelectorAll('.add-to-cart-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const product = JSON.parse(btn.dataset.product || '{}');

      if (window.CartAPI) {
        window.CartAPI.add(product);
      }

      btn.classList.add('added');
      btn.disabled = true;
      setTimeout(() => {
        btn.classList.remove('added');
        btn.disabled = false;
      }, 1800);
    });
  });
</script>
