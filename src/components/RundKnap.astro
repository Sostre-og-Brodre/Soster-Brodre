---
const { tekst, href, variant = "brun", target = "_self" } = Astro.props;
---

<a href={href} class={`btn btn--${variant}`} target={target}>
    {tekst}
</a>

<style>
    .btn {
        display: block;
        width: fit-content;
        padding: 1rem 1.5rem;
        border-radius: 9999px;
        font-family: Urbanist, sans-serif;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
        transition: opacity 0.2s ease;
    }

    .btn:hover {
        opacity: 0.8;
    }

    .btn--brun {
        background-color: #734d3f;
        color: white;
    }

    .btn--lysebrun {
        background-color: rgba(115, 77, 63, 0.6);
        color: white;
    }

    .btn--hvid {
        background-color: #ffffff;
        color: #734d3f;
        stroke: #734d3f;
    }
</style>
