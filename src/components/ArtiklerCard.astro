---
const { billede, billedeAlt, titel, kategori, dato, href } = Astro.props;
---

<a href={href} class="kort">
    <img src={billede} alt={billedeAlt} />
    <div class="indhold">
        <h3>{titel}</h3>
        <p class="kategori">{kategori}</p>
        <p class="dato">{dato}</p>
    </div>
</a>

<style>
    .kort {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background-color: #fff;
        text-decoration: none;
        color: inherit;
        max-width: 400px;
        transition: transform 0.2s;
    }

    .kort img {
        width: 100%;
        object-fit: cover;
    }

    .indhold {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    h3 {
        font-size: 1.1rem;
        font-weight: bold;
        line-height: 1.3;
    }

    .kategori {
        font-size: 0.9rem;
        color: #333;
        text-decoration: underline;
        margin-bottom: -1rem;
    }

    .dato {
        font-size: 0.85rem;
        color: #666;
    }

    @media (min-width: 768px) {
        h3 {
            font-size: 1.2rem;
        }
    }
</style>
