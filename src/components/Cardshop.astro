---
const { ShopData } = Astro.props;
import RundKnap from "../components/RundKnap.astro";
---

<article class="card">
  <img src={ShopData.Photo} alt={ShopData.Name} />
  <p class="navn"><strong>{ShopData.Name}</strong></p>
  <p class="pris">{ShopData.Price}kr</p>
  <div class="knap"><RundKnap tekst="KØB NU" href={"/button/" + ShopData.slug} /></div>
</article>

<style>
  article {
    display: contents;

  }

  img {
    width: 100%;
    aspect-ratio: 0.8;
    object-fit: cover;
    border-radius: 4px;
    border: 10px solid #a3bfb26b;
  }

  .navn {
    text-align: center;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pris {
    text-align: center;
    margin: 0;
  }

  .knap {
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
  }
</style>