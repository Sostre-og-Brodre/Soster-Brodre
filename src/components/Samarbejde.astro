---
const { titel, tekst, punkter } = Astro.props;
---

<div class="kort">
  <h3>{titel}</h3>
  <p>{tekst}</p>
  <ul>
    {punkter.map(punkt => <li>{punkt}</li>)}
  </ul>
</div>


<style>
    .kort {
      background-color: white;
      border-radius: 1.5rem;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    }


    li {
  font-family: "Urbanist", sans-serif;
  font-weight: 400;
  font-size: 14px;
  line-height: 25px;
  letter-spacing: 3%;
}

@media (min-width: 768px) {
li  {
    font-size: 20px;
    line-height: 30px;
    letter-spacing: 5%;
  }
}
</style> 