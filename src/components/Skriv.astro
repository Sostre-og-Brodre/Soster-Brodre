<style>
  .skriv {
    text-align: center;
    margin: 6rem auto 8rem;
    padding: 3rem 2rem 0;
  }

    .skriv h2 {
        margin-bottom: 1rem;
    }

    .skriv p {
        margin-bottom: 2rem;
    }

</style>
